{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "WebWorker"],
    "types": ["@cloudflare/workers-types", "@cloudflare/vitest-pool-workers"],
    "baseUrl": ".",
    "paths": {
      "cloudflare:test": ["test/cloudflare-test.d.ts"]
